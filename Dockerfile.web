FROM rust:1.88-bookworm AS builder
RUN rustup target add wasm32-unknown-unknown && cargo install trunk --locked
WORKDIR /src
COPY . .
RUN cargo build --release -p ebirforms-web
RUN cd apps/web/frontend && trunk build --release

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl && rm -rf /var/lib/apt/lists/* && useradd --system --uid 10001 --create-home ebirforms
WORKDIR /app
COPY --from=builder /src/target/release/ebirforms-web /usr/local/bin/ebirforms-web
COPY --from=builder /src/apps/web/frontend/dist /app/public
RUN mkdir /app/data && chown -R ebirforms:ebirforms /app
USER ebirforms
ENV EBIRFORMS_WEB_BIND=0.0.0.0:3000 EBIRFORMS_WEB_DB=/app/data/web.sqlite3 EBIRFORMS_WEB_STATIC_DIR=/app/public
VOLUME ["/app/data"]
EXPOSE 3000
CMD ["ebirforms-web"]
