{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "eBIRForms Desktop",
  "version": "0.1.0",
  "identifier": "app.navegante.ebirforms",
  "build": {
    "beforeDevCommand": "npm --prefix frontend install && scripts/ensure-trunk.sh serve --host 127.0.0.1 --port 1420",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm --prefix frontend install && scripts/ensure-trunk.sh build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "eBIRForms Desktop",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
